[Unit]
Description=INSIGHT.AI Streamlit UI
After=network.target insight-api.service

[Service]
User=ubuntu
WorkingDirectory=/opt/insight-ai/app
EnvironmentFile=/opt/insight-ai/.env
ExecStart=/opt/insight-ai/app/venv/bin/streamlit run functions/dashboard.py --server.address 127.0.0.1 --server.port 8501 --server.headless true
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
